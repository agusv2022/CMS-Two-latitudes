---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Página no encontrada" noindex={true}>
  <section class="section">
    <div class="wrap" style="text-align:center;padding:80px 0;">
      <p class="eyebrow">Error 404</p>
      <h1 style="font-size:clamp(40px,8vw,72px);margin:12px 0 18px;">Esta página no existe</h1>
      <p style="color:var(--muted);margin-bottom:26px;">Puede que el enlace esté roto o la página se haya movido.</p>
      <a href="/" class="btn">Volver al inicio</a>
    </div>
  </section>
</BaseLayout>
